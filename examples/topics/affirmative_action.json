  "fallback_tag": "affirmative_action_match",
  "tag_rules": [
    {
      "tag": "backlog_vacancies",
      "label": "Backlog reserved vacancies",
      "weight": 4,
      "patterns": [
        "backlog\\s+(reserved\\s+)?(vacanc|post)",
        "(SC|ST|OBC|EWS).{0,40}backlog",
        "backlog.{0,40}(SC|ST|OBC|EWS)"
      ]
    },
    {
      "tag": "promotion_in_reservation",
      "label": "Reservation in promotion",
      "weight": 4,
      "patterns": [
        "reservation\\s+in\\s+promotion",
        "promotion\\s+in\\s+reservation",
        "consequential\\s+seniority"
      ]
    },
    {
      "tag": "ews_quota",
      "label": "EWS reservation",
      "weight": 4,
      "patterns": [
        "Economically\\s+Weaker\\s+Section",
        "\\bEWS\\b.{0,40}(reservation|quota|post)",
        "10\\s*per\\s*cent\\s+reservation"
      ]
    },
    {
      "tag": "atrocities_act",
      "label": "SC/ST (Prevention of Atrocities) Act",
      "weight": 4,
      "patterns": [
        "Prevention\\s+of\\s+Atrocities\\s+Act",
        "\\bPOA\\s+Act\\b",
        "SC/ST\\s+Atrocities",
        "atrocities\\s+against\\s+(Dalits|Scheduled\\s+Castes|Scheduled\\s+Tribes|tribals)",
        "Protection\\s+of\\s+Civil\\s+Rights\\s+Act",
        "\\bPCR\\s+Act\\b"
      ]
    },
    {
      "tag": "post_creation",
      "label": "Post creation / sanctioned strength",
      "weight": 3,
      "patterns": [
        "creation\\s+of\\s+(reserved\\s+)?post",
        "sanctioned\\s+post.{0,80}(reserved|SC|ST|OBC|EWS)",
        "(reserved|SC|ST|OBC|EWS).{0,80}sanctioned\\s+post",
        "cadre\\s+review"
      ]
    },
    {
      "tag": "compassionate_appointment",
      "label": "Compassionate appointment",
      "weight": 3,
      "patterns": ["compassionate\\s+appointment"]
    },
    {
      "tag": "creamy_layer",
      "label": "Creamy layer",
      "weight": 3,
      "patterns": ["creamy\\s+layer"]
    },
    {
      "tag": "reservation_roster",
      "label": "Reservation roster",
      "weight": 3,
      "patterns": ["reservation\\s+roster", "200[- ]point\\s+roster", "13[- ]point\\s+roster"]
    },
    {
      "tag": "sc_st_reservation",
      "label": "SC/ST reservation",
      "weight": 2,
      "patterns": [
        "(Scheduled\\s+Castes?|Scheduled\\s+Tribes?|SC/ST).{0,80}reservation",
        "reservation.{0,80}(Scheduled\\s+Castes?|Scheduled\\s+Tribes?|SC/ST)"
      ]
    },
    {
      "tag": "obc_reservation",
      "label": "OBC reservation",
      "weight": 2,
      "patterns": [
        "Other\\s+Backward\\s+Classes",
        "\\bOBC\\b.{0,40}(reservation|quota|post)",
        "Mandal\\s+Commission"
      ]
    },
    {
      "tag": "general_reservation",
      "label": "Reservation (general)",
      "weight": 1,
      "patterns": ["\\breservation\\b", "reserved\\s+(post|categor|seat)"]
    }
  ]
}
